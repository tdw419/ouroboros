import ast
import os
import sys
import importlib.util
import json

# Configuration
SRC_DIR = os.path.join(os.path.dirname(__file__), 'src')
OUTPUT_FILE = os.path.join(os.path.dirname(__file__), 'tests/test_generated.py')

def get_source_files(directory):
"""Recursively find all Python files in the source directory."""
files = []
for root, _, filenames in os.walk(directory):
for filename in filenames:
if filename.endswith('.py'):
files.append(os.path.join(root, filename))
return files

def extract_structure(filepath):
"""Parse AST to extract classes, functions, and imports."""
try:
with open(filepath, 'r', encoding='utf-8') as f:
tree = ast.parse(f.read(), filename=filepath)
except SyntaxError as e:
print(f"Skipping {filepath} due to SyntaxError: {e}")
return None

structure = {
'file': filepath,
'module': os.path.relpath(filepath, SRC_DIR).replace(os.sep, '.')[:-3],
'classes': [],
'functions': [],
'imports': []
}

# Walk top-level nodes only initially to avoid duplication inside classes
for node in ast.iter_child_nodes(tree):
if isinstance(node, ast.ClassDef):
methods = [n.name for n in node.body if isinstance(n, ast.FunctionDef)]
structure['classes'].append({'name': node.name, 'methods': methods})
elif isinstance(node, ast.FunctionDef):
structure['functions'].append({
'name': node.name,
'args': [a.arg for a in node.args.args]
})
elif isinstance(node, (ast.Import, ast.ImportFrom)):
structure['imports'].append(ast.unparse(node))

return structure

def generate_test_code(structures):
"""Generate Python code for unittest based on extracted structure."""
lines = [
"import unittest",
"import sys",
"import os",
"from unittest.mock import MagicMock, patch, call",
"",
"sys.path.insert(0, os.path.join(os.path.dirname(__file__), '../src'))",
"",
"MODULES = {}",
""
]

# Generate Imports
imported_modules = set()
for s in structures:
if not s: continue
module_name = s['module']

# Normalize module name (e.g. src.ouroboros -> ouroboros if needed,
# but here we rely on sys.path trick)

lines.append(f"try:")
lines.append(f"    import {module_name}")
lines.append(f"    MODULES['{module_name}'] = sys.modules['{module_name}']")
lines.append(f"except ImportError as e:")
lines.append(f"    print(f'Warning: Could not import {module_name}: {{e}}')")
lines.append(f"")

lines.append("")
lines.append("class TestGeneratedCoverage(unittest.TestCase):")
lines.append("    \"\"\"Auto-generated test suite to maximize coverage.\"\"\"")

for s in structures:
if not s: continue
module_name = s['module']

# Test Functions
for func in s['functions']:
lines.append(f"    def test_{module_name.replace('.', '_')}_{func['name']}(self):")
lines.append(f"        self.assertIn('{module_name}', MODULES)")
lines.append(f"        mod = MODULES['{module_name}']")
lines.append(f"        self.assertTrue(hasattr(mod, '{func['name']}'))")

if func['args']:
args_str = ", ".join(["MagicMock()" for _ in func['args']])
lines.append(f"        try:")
lines.append(f"            mod.{func['name']}({args_str})")
lines.append(f"        except Exception as e:")
lines.append(f"            self.fail(f\"Function call failed: {{e}}\")")
else:
lines.append(f"        try:")
lines.append(f"            mod.{func['name']}()")
lines.append(f"        except Exception:")
lines.append(f"            pass # Expected to fail if it needs state")
lines.append("")

# Test Classes
for cls in s['classes']:
cls_name = cls['name']
lines.append(f"    def test_{module_name.replace('.', '_')}_class_{cls_name}(self):")
lines.append(f"        self.assertIn('{module_name}', MODULES)")
lines.append(f"        mod = MODULES['{module_name}']")
lines.append(f"        self.assertTrue(hasattr(mod, '{cls_name}'))")
lines.append(f"        try:")
lines.append(f"            instance = getattr(mod, '{cls_name}')()")
lines.append(f"        except Exception as e:")
lines.append(f"            # Allow instantiation errors, just check existence")
lines.append(f"            pass")
lines.append("")

# Test Methods
for method in cls['methods']:
lines.append(f"    def test_{module_name.replace('.', '_')}_class_{cls_name}_{method}(self):")
lines.append(f"        self.assertIn('{module_name}', MODULES)")
lines.append(f"        mod = MODULES['{module_name}']")
lines.append(f"        Cls = getattr(mod, '{cls_name}')")
lines.append(f"        self.assertTrue(hasattr(Cls, '{method}'))")
lines.append("")

# Footer
lines.append("")
lines.append("if __name__ == '__main__':")
lines.append("    unittest.main()")

return "\n".join(lines)

def main():
if not os.path.exists(SRC_DIR):
print(f"Source directory {SRC_DIR} not found.")
return

files = get_source_files(SRC_DIR)
if not files:
print("No source files found.")
return

print(f"Analyzing {len(files)} files...")
structures = [extract_structure(f) for f in files]
structures = [s for s in structures if s is not None]

code = generate_test_code(structures)

os.makedirs(os.path.dirname(OUTPUT_FILE), exist_ok=True)
with open(OUTPUT_FILE, 'w', encoding='utf-8') as f:
f.write(code)

print(f"Generated tests written to {OUTPUT_FILE}")

if __name__ == "__main__":
main()